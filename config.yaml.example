# ScholarAIO configuration 配置文件

paths:
  papers_dir: data/papers # Ingested papers directory 已入库论文目录
  index_db: data/index.db # SQLite index file SQLite 索引文件

# LLM backend LLM 后端配置
# Put api_key in config.local.yaml (gitignored) or use env vars:
# 敏感信息（api_key）放 config.local.yaml（不进 git），或用环境变量：
#   SCHOLARAIO_LLM_API_KEY / DEEPSEEK_API_KEY / OPENAI_API_KEY
llm:
  backend: openai-compat # openai-compat | anthropic
  model: deepseek-chat
  base_url: https://api.deepseek.com
  api_key: null # → config.local.yaml
  timeout: 30 # Normal LLM call timeout (sec) 普通调用超时（秒）
  timeout_toc: 120 # enrich-toc timeout enrich-toc 超时
  timeout_clean: 90 # validate_and_clean timeout 结论清洗超时

# Ingest pipeline 数据入库管道
ingest:
  extractor: robust # auto | regex | llm | robust
  mineru_endpoint: http://localhost:8000 # Local MinerU API 本地 MinerU API
  mineru_cloud_url: https://mineru.net/api/v4 # Cloud MinerU API 云端 MinerU API
  mineru_api_key: null # → config.local.yaml or env MINERU_API_KEY
  abstract_llm_mode: verify # off | fallback | verify
  contact_email: null # Crossref polite pool email → config.local.yaml

# Semantic embeddings 语义向量
embed:
  model: Qwen/Qwen3-Embedding-0.6B
  cache_dir: ~/.cache/modelscope/hub/models
  device: auto # auto | cpu | cuda
  top_k: 10 # vsearch default results vsearch 默认返回条数
  source: modelscope # modelscope (China) | huggingface (international) 模型下载源

search:
  top_k: 20 # FTS5 search default results 关键词搜索默认返回条数

# Reranker 重排序（融合检索后精排）
reranker:
  enabled: true # Enable reranker after hybrid search 融合检索后启用重排序
  model: BAAI/bge-reranker-v2-m3 # CrossEncoder model CrossEncoder 模型
  device: auto # auto | cpu | cuda
  top_k: 0 # 0 = use search top_k; N = override 0=沿用检索top_k
  source: modelscope # modelscope (China) | huggingface (international) 模型下载源

# Logging & metrics 日志与指标
logging:
  level: INFO
  file: data/scholaraio.log
  max_bytes: 10000000 # 10 MB, rotate on overflow 超出轮转
  backup_count: 3
  metrics_db: data/metrics.db

# Image generation 图片生成（Gemini via VectorEngine）
# 敏感信息（api_key）放 config.local.yaml，或用环境变量：
#   VECTORENGINE_API_KEY / IMAGE_GEN_API_KEY
image_gen:
  base_url: https://api.vectorengine.ai   # VectorEngine 代理地址
  model: ""                               # 留空则自动选择（native: gemini-2.5-flash-image / chat: gemini-2.0-flash-exp-image-generation）
  api_key: null                           # → config.local.yaml
  output_dir: workspace/images            # 生成图片保存目录
  timeout: 120                            # 超时（秒），图片生成耗时较长
  format: native                          # native（Gemini 原生格式）| chat（OpenAI 兼容格式）

# Topic modeling 主题建模
topics:
  min_topic_size: 5 # HDBSCAN min cluster size 最小聚类大小
  nr_topics: -1 # 0=auto, -1=no merge, N=target count 目标主题数
  model_dir: data/topic_model # Model save directory 模型保存目录
